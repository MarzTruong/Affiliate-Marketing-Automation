# ============================================================
# Affiliate Marketing Automation - Environment Configuration
# Copy to .env (dev) or .env.prod (production)
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_NAME=affiliate-marketing-automation
APP_ENV=development
DEBUG=true

# ── Database ────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=affiliate_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/affiliate_db

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Ports (for docker-compose.prod.yml) ─────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_PORT=80

# ── Anthropic Claude API (REQUIRED for AI content) ─────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
CLAUDE_DAILY_COST_LIMIT_USD=20.00

# ── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Shopee ──────────────────────────────────────────────────
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_ACCESS_TOKEN=
SHOPEE_SHOP_ID=

# ── Lazada ──────────────────────────────────────────────────
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_ACCESS_TOKEN=

# ── TikTok Shop ────────────────────────────────────────────
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── ShopBack ───────────────────────────────────────────────
SHOPBACK_PARTNER_ID=
SHOPBACK_API_KEY=

# ── AccessTrade VN ─────────────────────────────────────────
ACCESSTRADE_API_KEY=
ACCESSTRADE_SITE_ID=

# ── Facebook Publisher ─────────────────────────────────────
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# ── WordPress Publisher ────────────────────────────────────
WORDPRESS_SITE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# ── Telegram Publisher ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
